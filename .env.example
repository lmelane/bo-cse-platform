# =============================================
# Required — MUST be set in production (Vercel)
# =============================================

# URL de l'API backend (REQUIRED in production)
NEXT_PUBLIC_API_URL=http://localhost:3001

# URL du site frontend pour voir les événements publics (REQUIRED in production)
NEXT_PUBLIC_FRONTEND_URL=http://localhost:3000

# =============================================
# Optional — sensible defaults in lib/config.ts
# =============================================

# Google Maps (restrict to your domains in GCP Console)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Network timeouts (ms)
# NEXT_PUBLIC_API_TIMEOUT=30000
# NEXT_PUBLIC_AUTH_TIMEOUT=15000

# Session re-validation interval (ms, default: 5 min)
# NEXT_PUBLIC_SESSION_CHECK_INTERVAL=300000
